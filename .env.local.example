# ── Görsel Üretim API ─────────────────────────────────────────────────────
VERTEX_API_KEY=sk-...

# ── Admin Paneli ───────────────────────────────────────────────────────────
ADMIN_PASSWORD=sifreniz

# ── Vercel KV (Upstash Redis) — Vercel Dashboard > Integrations > Upstash ──
# Vercel'de otomatik set edilir; yerel geliştirmede opsiyonel (dosya sistemi kullanılır)
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ── Vercel Blob — Vercel Dashboard > Storage > Blob ────────────────────────
# Vercel'de otomatik set edilir; yerel geliştirmede opsiyonel (public/generated kullanılır)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ── (Kullanılmıyor, ileride gerekirse) ────────────────────────────────────
GEMINI_API_KEY=AIza...
FAL_API_KEY=...